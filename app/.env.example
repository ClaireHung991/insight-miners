# ── Google AI Studio ─────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=False

# ── Models — configurable per agent role ──────────────────────────────────────
# Swap model names without changing code. Defaults shown below.
ORCHESTRATOR_MODEL=gemini-2.5-flash
RESEARCH_MODEL=gemini-2.5-flash
WRITER_MODEL=gemini-2.5-flash
EDITOR_MODEL=gemini-2.5-flash
RECOMMENDATION_MODEL=gemini-2.5-pro

# ── Speech-to-Text (OpenAI Whisper API) ──────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# ── Miro Integration (REST API v2) ───────────────────────────────────────────
# Create a Miro Developer App and generate an access token with board read/write:
# https://developers.miro.com/docs/getting-started
MIRO_ACCESS_TOKEN=your-miro-access-token-here
